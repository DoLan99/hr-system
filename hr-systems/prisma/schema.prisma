// ─────────────────────────────────────────────────────────────
// APPROVAL WORKFLOW ENGINE (Sprint 2)
// ─────────────────────────────────────────────────────────────

model WorkflowTemplate {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  targetType     WorkflowTargetType
  isActive       Boolean              @default(true)
  steps          WorkflowStep[]
  instances      WorkflowInstance[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId])
  @@map("workflow_templates")
}

model WorkflowStep {
  id            Int                @id @default(autoincrement())
  templateId    String
  template      WorkflowTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  stepOrder     Int
  name          String
  approverType  WorkflowApprover
  approverRef   String?            // roleId (số) hoặc employeeId (số), tuỳ approverType
  slaHours      Int?               // null = không giới hạn
  approvals     WorkflowApproval[]

  @@unique([templateId, stepOrder])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id             String            @id @default(cuid())
  templateId     String
  template       WorkflowTemplate  @relation(fields: [templateId], references: [id])
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetType     WorkflowTargetType
  targetId       String            // ID của Leave / Document / ...
  status         WorkflowStatus    @default(RUNNING)
  currentStep    Int               @default(1)
  initiatorId    Int
  initiator      Employee          @relation("WorkflowInitiator", fields: [initiatorId], references: [id])
  approvals      WorkflowApproval[]
  startedAt      DateTime          @default(now())
  completedAt    DateTime?

  @@index([organizationId, status])
  @@index([targetType, targetId])
  @@map("workflow_instances")
}

model WorkflowApproval {
  id          String            @id @default(cuid())
  instanceId  String
  instance    WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId      Int
  step        WorkflowStep      @relation(fields: [stepId], references: [id])
  stepOrder   Int
  approverId  Int?
  approver    Employee?         @relation("WorkflowApprover", fields: [approverId], references: [id])
  action      ApprovalAction?
  comment     String?
  actedAt     DateTime?
  dueAt       DateTime?

  @@index([instanceId])
  @@index([approverId, action])
  @@map("workflow_approvals")
}

enum WorkflowTargetType {
  LEAVE
  DOCUMENT
  PURCHASE
  TIMELOG
  CUSTOM
}

enum WorkflowStatus {
  RUNNING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowApprover {
  ROLE
  SPECIFIC_EMPLOYEE
  DEPARTMENT_HEAD
  DIRECT_MANAGER
}

enum ApprovalAction {
  APPROVED
  REJECTED
  DELEGATED
}

// ─────────────────────────────────────────────────────────────
// INVENTORY MANAGEMENT (Sprint 3)
// ─────────────────────────────────────────────────────────────

model InventoryCategory {
  id             Int             @id @default(autoincrement())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  description    String?
  items          InventoryItem[]
  createdAt      DateTime        @default(now())

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("inventory_categories")
}

model InventoryItem {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  categoryId     Int
  category       InventoryCategory    @relation(fields: [categoryId], references: [id])
  name           String
  sku            String?
  unit           String               @default("cái")
  quantity       Int                  @default(0)
  minQuantity    Int                  @default(0)
  costPrice      Decimal?             @db.Decimal(15, 2)
  location       String?
  description    String?
  imageUrl       String?
  transactions   InventoryTransaction[]
  assignments    InventoryAssignment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, categoryId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           InventoryItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type           InventoryTxType
  quantity       Int
  note           String?
  referenceNo    String?
  actorId        Int
  actor          Employee         @relation(fields: [actorId], references: [id])
  createdAt      DateTime         @default(now())

  @@index([organizationId])
  @@index([itemId])
  @@map("inventory_transactions")
}

model InventoryAssignment {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  employeeId     Int
  employee       Employee      @relation(fields: [employeeId], references: [id])
  quantity       Int           @default(1)
  assignedAt     DateTime      @default(now())
  returnedAt     DateTime?
  note           String?

  @@index([organizationId])
  @@index([employeeId])
  @@map("inventory_assignments")
}

enum InventoryTxType {
  IN
  OUT
  ADJUST
  RETURN
}

// ─────────────────────────────────────────────────────────────
// MICROSOFT GRAPH / ONEDRIVE INTEGRATION (Sprint 1)
// ─────────────────────────────────────────────────────────────

model MicrosoftToken {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessToken    String       @db.Text
  refreshToken   String       @db.Text
  expiresAt      DateTime
  scope          String
  msUserId       String?
  msUserEmail    String?
  msUserName     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("microsoft_tokens")
}

model DrivePermission {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  driveItemId    String
  grantedToId    Int?
  grantedTo      Employee?       @relation(fields: [grantedToId], references: [id], onDelete: Cascade)
  grantedToRole  String?
  level          DriveAccessLevel @default(VIEW)
  createdAt      DateTime        @default(now())

  @@unique([organizationId, driveItemId, grantedToId])
  @@index([organizationId, driveItemId])
  @@map("drive_permissions")
}

enum DriveAccessLevel {
  VIEW
  EDIT
  ADMIN
}

enum SkillImportance {
  CRITICAL
  IMPORTANT
  NICE_TO_HAVE
}
