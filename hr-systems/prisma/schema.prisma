generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ORGANIZATIONS (Multi-tenant root)
// ─────────────────────────────────────────────────────────────

model Organization {
  id                   String           @id @default(cuid())
  clerkOrgId           String           @unique
  slug                 String           @unique
  name                 String
  logoUrl              String?
  plan                 Plan             @default(FREE)
  status               OrgStatus        @default(ACTIVE)
  seatLimit            Int              @default(1)

  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  trialEndsAt          DateTime?

  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  // Relations to all tenant-scoped models
  employees            Employee[]
  roles                Role[]
  departments          Department[]
  teams                Team[]
  teamDepartments      TeamDepartment[]
  salaryHistory        SalaryHistory[]
  customers            Customer[]
  taskTemplates        TaskTemplate[]
  tasks                Task[]
  timeLogs             TimeLog[]
  officeTimes          OfficeTime[]
  templateSuggestions  TemplateSuggestion[]
  estimateFlags        EstimateFlag[]
  salarySummaries      SalarySummary[]
  payments             Payment[]
  leaves               Leave[]
  messages             Message[]
  messageAuditLogs     MessageAuditLog[]
  passwordVaults       PasswordVault[]
  vaultAccessLogs      VaultAccessLog[]
  workRules            WorkRule[]
  userSessions         UserSession[]
  userActivities       UserActivity[]
  apiAccessLogs        ApiAccessLog[]
  anomalyAlerts        AnomalyAlert[]
  auditLogs            AuditLog[]
  systemLabels         SystemLabel[]
  reviewCycles         ReviewCycle[]
  performanceReviews   PerformanceReview[]
  skills               Skill[]
  employeeSkills       EmployeeSkill[]
  roleSkillRequirements RoleSkillRequirement[]
  microsoftToken        MicrosoftToken?
  drivePermissions      DrivePermission[]
  workflowTemplates     WorkflowTemplate[]
  workflowInstances     WorkflowInstance[]
  inventoryCategories   InventoryCategory[]
  inventoryItems        InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  inventoryAssignments  InventoryAssignment[]
  channelIntegrations   ChannelIntegration[]

  @@map("organizations")
}

// ─────────────────────────────────────────────────────────────
// ROLES & EMPLOYEES
// ─────────────────────────────────────────────────────────────

model Role {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  label          String
  description    String?
  color          String?
  permissions    Json         @default("{}")
  seniority      Int          @default(0)
  employees      Employee[]
  skillRequirements RoleSkillRequirement[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model Department {
  id             Int              @id @default(autoincrement())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  description    String?
  headId         Int?
  head           Employee?        @relation("DeptHead", fields: [headId], references: [id])
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  teams          TeamDepartment[]
  employees      Employee[]       @relation("EmployeeDept")

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model Team {
  id             Int              @id @default(autoincrement())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  departments    TeamDepartment[]
  leadId         Int?
  lead           Employee?        @relation("TeamLead", fields: [leadId], references: [id])
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  employees      Employee[]       @relation("EmployeeTeam")

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model TeamDepartment {
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamId         Int
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  departmentId   Int
  department     Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([teamId, departmentId])
  @@index([organizationId])
  @@map("team_departments")
}

model Employee {
  id              Int          @id @default(autoincrement())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clerkUserId     String       // Link to Clerk user (no FK — Clerk is source of truth)
  membershipRole  MembershipRole @default(MEMBER)
  isOwner         Boolean      @default(false)

  employeeCode    String?
  fullName        String
  avatarUrl       String?
  department      String?
  departmentId    Int?
  dept            Department?  @relation("EmployeeDept", fields: [departmentId], references: [id])
  teamId          Int?
  team            Team?        @relation("EmployeeTeam", fields: [teamId], references: [id])
  roleId          Int
  role            Role         @relation(fields: [roleId], references: [id])
  company         String?
  emailCompany    String
  emailGoogle     String?
  emailPrivate    String?
  mobileCompany   String?
  payType         PayType      @default(HOURLY)
  hourlyRate      Decimal?     @db.Decimal(10, 2)
  monthlySalary   Decimal?     @db.Decimal(10, 2)
  maxHoursMonth   Int          @default(160)
  bonusMPct       Decimal      @default(0) @db.Decimal(5, 2)
  bonusAPct       Decimal      @default(0) @db.Decimal(5, 2)
  bonusTPct       Decimal      @default(0) @db.Decimal(5, 2)
  driveLink1      String?
  driveLink2      String?
  driveLink3      String?
  driveLink4      String?
  startDate       DateTime?
  managerId       Int?
  manager         Employee?    @relation("ManagerEmployee", fields: [managerId], references: [id])
  subordinates    Employee[]   @relation("ManagerEmployee")
  status          EmployeeStatus @default(ACTIVE)
  locale          String       @default("en")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Department/Team head relations
  departmentsLed       Department[]          @relation("DeptHead")
  teamsLed             Team[]                @relation("TeamLead")

  // Tasks & Time Logs
  tasksAssigned        Task[]                @relation("TaskAssignee")
  tasksCreated         Task[]                @relation("TaskCreator")
  timeLogs             TimeLog[]             @relation("TimeLogEmployee")
  approvedTimeLogs     TimeLog[]             @relation("TimeLogApprover")

  // Templates & Reviews
  templatesCreated     TaskTemplate[]        @relation("TemplateCreator")
  templateSuggestions  TemplateSuggestion[]  @relation("SuggestionEmployee")
  reviewedSuggestions  TemplateSuggestion[]  @relation("SuggestionReviewer")
  reviewedFlags        EstimateFlag[]        @relation("FlagReviewer")

  // Other relations
  officeTimes          OfficeTime[]
  salarySummaries      SalarySummary[]
  payments             Payment[]             @relation("PaymentEmployee")
  paymentsCreated      Payment[]             @relation("PaymentCreator")
  leaves               Leave[]
  messages             Message[]
  messageAuditLogs     MessageAuditLog[]     @relation("MessageAuditActor")
  salaryHistory        SalaryHistory[]
  auditLogs            AuditLog[]
  vaultAccesses        VaultAccessLog[]
  passwordVaultOwned   PasswordVault[]       @relation("VaultOwner")
  customersManaged     Customer[]            @relation("CustomerStaff")
  approvedOfficeTimes  OfficeTime[]          @relation("ApprovedBy")
  approvedLeaves       Leave[]               @relation("LeaveApprover")
  confirmedSummaries   SalarySummary[]       @relation("SummaryConfirmer")
  salaryHistoryMaker   SalaryHistory[]       @relation("SalaryHistoryChanger")

  // Performance Reviews
  reviewCyclesCreated  ReviewCycle[]         @relation("ReviewCycleCreator")
  performanceReviews   PerformanceReview[]   @relation("PerfReviewEmployee")
  performanceReviewsAsManager PerformanceReview[] @relation("PerfReviewManager")

  // Skills
  employeeSkills       EmployeeSkill[]       @relation("EmpSkillEmployee")
  verifiedEmployeeSkills EmployeeSkill[]     @relation("EmpSkillVerifier")

  // Drive permissions
  drivePermissions          DrivePermission[]

  // Workflow
  workflowsInitiated        WorkflowInstance[]   @relation("WorkflowInitiator")
  workflowApprovalsAssigned WorkflowApproval[]   @relation("WorkflowApprover")

  // Inventory
  inventoryTransactions     InventoryTransaction[]
  inventoryAssignments      InventoryAssignment[]

  // Tracking layer
  userSessions         UserSession[]
  apiAccessLogs        ApiAccessLog[]
  userActivities       UserActivity[]
  anomalyAlerts        AnomalyAlert[]        @relation("AnomalyAlertEmployee")
  anomalyAcksMade      AnomalyAlert[]        @relation("AnomalyAlertAcknowledger")

  @@unique([organizationId, emailCompany])
  @@unique([organizationId, employeeCode])
  @@unique([organizationId, clerkUserId])
  @@index([organizationId])
  @@index([clerkUserId])
  @@map("employees")
}

model SalaryHistory {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId     Int
  employee       Employee     @relation(fields: [employeeId], references: [id])
  field          String
  oldValue       String?
  newValue       String?
  changedById    Int
  changedBy      Employee     @relation("SalaryHistoryChanger", fields: [changedById], references: [id])
  changedAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("salary_history")
}

// ─────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────

model Customer {
  id                Int          @id @default(autoincrement())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  custId            String?
  customerName      String?
  businessName      String?
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  city              String?
  plz               String?
  website           String?
  vatTaxId          String?
  preferredLanguage String?
  status            CustomerStatus @default(ACTIVE)
  responsibleStaffId Int?
  responsibleStaff  Employee?    @relation("CustomerStaff", fields: [responsibleStaffId], references: [id])
  lastContactDate   DateTime?
  notes             String?
  createdAt         DateTime     @default(now())

  tasks         Task[]
  messages      Message[]
  passwordVault PasswordVault[]

  @@unique([organizationId, custId])
  @@index([organizationId])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────
// TASK TEMPLATES
// ─────────────────────────────────────────────────────────────

model TaskTemplate {
  id                    Int          @id @default(autoincrement())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code                  String
  title                 String
  description           String?      @db.Text
  defaultTaskType       TaskType     @default(NORMAL)
  defaultEstimatedTime  Int?
  defaultPriority       Priority     @default(NORMAL)
  requiresVideo         Boolean?
  department            String?
  linkTemplate          String?
  usageCount            Int          @default(0)
  isActive              Boolean      @default(true)
  createdById           Int?
  createdBy             Employee?    @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt             DateTime     @default(now())

  tasks                 Task[]
  estimateFlags         EstimateFlag[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("task_templates")
}

// ─────────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────────

model Task {
  id                  Int          @id @default(autoincrement())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code                String
  title               String
  description         String?      @db.Text
  taskType            TaskType     @default(NORMAL)
  priority            Priority     @default(NORMAL)
  status              TaskStatus   @default(BACKLOG)
  estimatedTime       Int?
  actualTimeTotal     Int          @default(0)
  progressPct         Int          @default(0)

  parentTaskId        Int?
  parentTask          Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks            Task[]       @relation("TaskHierarchy")

  templateId          Int?
  template            TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  assignedToId        Int
  assignedTo          Employee     @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedById        Int
  assignedBy          Employee     @relation("TaskCreator", fields: [assignedById], references: [id])

  customerId          Int?
  customer            Customer?    @relation(fields: [customerId], references: [id])
  projectId           Int?

  billable            Boolean      @default(false)
  hourlyRateOverride  Decimal?     @db.Decimal(10, 2)
  requiresVideo       Boolean      @default(false)
  videoLink           String?

  dateCreated         DateTime     @default(now())
  dateStarted         DateTime?
  dueDate             DateTime?
  dateCompleted       DateTime?
  isOverdue           Boolean      @default(false)
  lastUpdate          DateTime     @default(now()) @updatedAt
  reasonNextAction    String?

  timeLogs            TimeLog[]

  @@unique([organizationId, code])
  @@index([organizationId, assignedToId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, parentTaskId])
  @@index([organizationId, dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// TIME LOGS
// ─────────────────────────────────────────────────────────────

model TimeLog {
  id                   Int                @id @default(autoincrement())
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  taskId               Int
  task                 Task               @relation(fields: [taskId], references: [id], onDelete: Restrict)
  employeeId           Int
  employee             Employee           @relation("TimeLogEmployee", fields: [employeeId], references: [id])

  date                 DateTime
  startTime            DateTime?
  endTime              DateTime?
  durationMinutes      Int
  quantity             Int                @default(1)
  note                 String?            @db.Text
  completionPctAfter   Int?
  taskStatusAfter      TaskStatus?

  videoCount           Int                @default(0)
  videoDuration        Int                @default(0)
  videoLink            String?
  proofLinks           Json               @default("[]")

  creditedMinutes      Int?
  approvalStatus       TimeLogApprovalStatus @default(PENDING)
  approvedById         Int?
  approvedBy           Employee?          @relation("TimeLogApprover", fields: [approvedById], references: [id])
  approvedMinutes      Int?
  approvedAt           DateTime?
  rejectionReason      String?
  rating               Int?

  createdAt            DateTime           @default(now())

  @@index([organizationId, taskId])
  @@index([organizationId, employeeId, date])
  @@index([organizationId, approvalStatus])
  @@map("time_logs")
}

// ─────────────────────────────────────────────────────────────
// OFFICE TIME
// ─────────────────────────────────────────────────────────────

model OfficeTime {
  id                   Int            @id @default(autoincrement())
  organizationId       String
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date                 DateTime
  employeeId           Int
  employee             Employee       @relation(fields: [employeeId], references: [id])
  startWork1           DateTime?
  startLunch           DateTime?
  startWork2           DateTime?
  startAfternoonBreak  DateTime?
  startWork3           DateTime?
  endWorkday           DateTime?
  timeLogsTotal        Int            @default(0)
  actualWorked         Int?
  delta                Int?
  explanation          String?
  approvalStatus       ApprovalStatus @default(PENDING)
  approvedById         Int?
  approvedBy           Employee?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedDelta        Int?
  approvedAt           DateTime?
  createdAt            DateTime       @default(now())

  @@unique([organizationId, date, employeeId])
  @@index([organizationId])
  @@map("office_time")
}

// ─────────────────────────────────────────────────────────────
// TASK REVIEWS
// ─────────────────────────────────────────────────────────────

model TemplateSuggestion {
  id                    Int            @id @default(autoincrement())
  organizationId        String
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date                  DateTime       @default(now())
  employeeId            Int
  employee              Employee       @relation("SuggestionEmployee", fields: [employeeId], references: [id])
  proposedCode          String
  proposedTitle         String
  description           String         @db.Text
  proposedTaskType      TaskType
  proposedEstimate      Int
  evidenceVideoLink     String
  exampleTaskIds        Json           @default("[]")
  reasonNote            String         @db.Text
  status                ApprovalStatus @default(PENDING)
  reviewedById          Int?
  reviewedBy            Employee?      @relation("SuggestionReviewer", fields: [reviewedById], references: [id])
  createdTemplateId     Int?
  decisionNote          String?
  bonusTime             Int            @default(0)
  reviewedAt            DateTime?
  createdAt             DateTime       @default(now())

  @@index([organizationId])
  @@map("template_suggestions")
}

model EstimateFlag {
  id                    Int                @id @default(autoincrement())
  organizationId        String
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  templateId            Int
  template              TaskTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flaggedAt             DateTime           @default(now())
  currentEstimate       Int
  suggestedEstimate     Int
  sampleSize            Int
  status                EstimateFlagStatus @default(OPEN)
  reviewedById          Int?
  reviewedBy            Employee?          @relation("FlagReviewer", fields: [reviewedById], references: [id])
  reviewedAt            DateTime?

  @@index([organizationId])
  @@map("estimate_flags")
}

// ─────────────────────────────────────────────────────────────
// SUMMARY & PAYMENTS
// ─────────────────────────────────────────────────────────────

model SalarySummary {
  id                     Int          @id @default(autoincrement())
  organizationId         String
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId             Int
  employee               Employee     @relation(fields: [employeeId], references: [id])
  month                  Int
  year                   Int
  creditedHours          Decimal      @default(0) @db.Decimal(8, 2)
  workHoursReal          Decimal      @default(0) @db.Decimal(8, 2)
  learnHours             Decimal      @default(0) @db.Decimal(8, 2)
  billableHours          Decimal      @default(0) @db.Decimal(8, 2)
  billableAmount         Decimal      @default(0) @db.Decimal(10, 2)
  deltaHours             Decimal      @default(0) @db.Decimal(8, 2)
  salaryCalc             Decimal      @default(0) @db.Decimal(10, 2)
  bonusCalc              Decimal      @default(0) @db.Decimal(10, 2)
  totalCalc              Decimal      @default(0) @db.Decimal(10, 2)
  salaryPaid             Decimal      @default(0) @db.Decimal(10, 2)
  bonusPaid              Decimal      @default(0) @db.Decimal(10, 2)
  moneyReceived          Decimal      @default(0) @db.Decimal(10, 2)
  deltaMoney             Decimal      @default(0) @db.Decimal(10, 2)
  scoreWorkSpeed         Decimal?     @db.Decimal(5, 2)
  scoreQuality           Decimal?     @db.Decimal(5, 2)
  scoreLearning          Decimal?     @db.Decimal(5, 2)
  scoreDeadlines         Decimal?     @db.Decimal(5, 2)
  scoreInitiative        Decimal?     @db.Decimal(5, 2)
  totalScore             Decimal?     @db.Decimal(5, 2)
  totalTasks             Int          @default(0)
  completedTasks         Int          @default(0)
  openTasks              Int          @default(0)
  overdueTasks           Int          @default(0)
  totalActualTimeH       Decimal      @default(0) @db.Decimal(8, 2)
  totalCreditedTimeH     Decimal      @default(0) @db.Decimal(8, 2)
  completionRate         Decimal      @default(0) @db.Decimal(5, 2)
  tasksByType            Json?
  confirmedById          Int?
  confirmedBy            Employee?    @relation("SummaryConfirmer", fields: [confirmedById], references: [id])
  confirmedAt            DateTime?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([organizationId, employeeId, month, year])
  @@index([organizationId])
  @@map("salary_summary")
}

model Payment {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime
  employeeId     Int
  employee       Employee     @relation("PaymentEmployee", fields: [employeeId], references: [id])
  type           PaymentType
  amount         Decimal      @db.Decimal(10, 2)
  notes          String?
  summaryMonth   Int?
  summaryYear    Int?
  createdById    Int?
  createdBy      Employee?    @relation("PaymentCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// PERFORMANCE REVIEWS
// ─────────────────────────────────────────────────────────────

model ReviewCycle {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  periodType     ReviewPeriodType @default(QUARTERLY)
  periodStart    DateTime
  periodEnd      DateTime
  selfDueDate    DateTime?
  managerDueDate DateTime?
  status         ReviewCycleStatus @default(DRAFT)
  createdById    Int
  createdBy      Employee     @relation("ReviewCycleCreator", fields: [createdById], references: [id])
  openedAt       DateTime?
  closedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reviews        PerformanceReview[]

  @@index([organizationId, status])
  @@map("review_cycles")
}

model PerformanceReview {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cycleId        Int
  cycle          ReviewCycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employeeId     Int
  employee       Employee     @relation("PerfReviewEmployee", fields: [employeeId], references: [id])
  status         PerfReviewStatus @default(PENDING)

  // Auto-KPI snapshot (frozen at cycle creation)
  kpiSnapshot    Json?

  // Self review section
  selfScoreWorkSpeed   Decimal? @db.Decimal(5, 2)
  selfScoreQuality     Decimal? @db.Decimal(5, 2)
  selfScoreLearning    Decimal? @db.Decimal(5, 2)
  selfScoreDeadlines   Decimal? @db.Decimal(5, 2)
  selfScoreInitiative  Decimal? @db.Decimal(5, 2)
  selfTotalScore       Decimal? @db.Decimal(5, 2)
  selfHighlights       String?  @db.Text
  selfChallenges       String?  @db.Text
  selfGoalsNext        String?  @db.Text
  selfSubmittedAt      DateTime?

  // Manager review section
  mgrScoreWorkSpeed    Decimal? @db.Decimal(5, 2)
  mgrScoreQuality      Decimal? @db.Decimal(5, 2)
  mgrScoreLearning     Decimal? @db.Decimal(5, 2)
  mgrScoreDeadlines    Decimal? @db.Decimal(5, 2)
  mgrScoreInitiative   Decimal? @db.Decimal(5, 2)
  mgrTotalScore        Decimal? @db.Decimal(5, 2)
  mgrStrengths         String?  @db.Text
  mgrAreasToImprove    String?  @db.Text
  mgrActionItems       String?  @db.Text
  recommendedSalaryAdjustPct Decimal? @db.Decimal(5, 2)
  recommendedPromotion String?  @db.Text
  mgrReviewerId        Int?
  mgrReviewer          Employee? @relation("PerfReviewManager", fields: [mgrReviewerId], references: [id])
  mgrSubmittedAt       DateTime?
  finalizedAt          DateTime?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, cycleId, employeeId])
  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@map("performance_reviews")
}

// ─────────────────────────────────────────────────────────────
// SKILLS & CAREER PATH
// ─────────────────────────────────────────────────────────────

model Skill {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  category       String?
  description    String?      @db.Text
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  employeeSkills EmployeeSkill[]
  roleRequirements RoleSkillRequirement[]

  @@unique([organizationId, name])
  @@index([organizationId, category])
  @@map("skills")
}

model EmployeeSkill {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId     Int
  employee       Employee     @relation("EmpSkillEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  skillId        Int
  skill          Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  currentLevel   Int          @default(1)
  targetLevel    Int?
  notes          String?      @db.Text
  verifiedById   Int?
  verifiedBy     Employee?    @relation("EmpSkillVerifier", fields: [verifiedById], references: [id])
  verifiedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, employeeId, skillId])
  @@index([organizationId, employeeId])
  @@map("employee_skills")
}

model RoleSkillRequirement {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleId         Int
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  skillId        Int
  skill          Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  requiredLevel  Int          @default(3)
  importance     SkillImportance @default(IMPORTANT)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, roleId, skillId])
  @@index([organizationId, roleId])
  @@map("role_skill_requirements")
}

// ─────────────────────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Leave {
  id               Int            @id @default(autoincrement())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date             DateTime
  employeeId       Int
  employee         Employee       @relation(fields: [employeeId], references: [id])
  type             LeaveType
  requestedHours   Decimal        @db.Decimal(5, 2)
  reason           String?
  evidenceLink     String?
  status           ApprovalStatus @default(PENDING)
  approvedHours    Decimal?       @db.Decimal(5, 2)
  approvalNote     String?
  approvedById     Int?
  approvedBy       Employee?      @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  money            Decimal?       @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())

  @@index([organizationId])
  @@map("leaves")
}

// ─────────────────────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────────────────────

model Message {
  id             Int            @id @default(autoincrement())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime
  time           DateTime?
  channel        MessageChannel?
  customerId     Int?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  subject        String?
  messageSummary String?
  actionRequired String?
  assignedToId   Int?
  assignedTo     Employee?      @relation(fields: [assignedToId], references: [id])
  dueDate        DateTime?
  status         MessageStatus  @default(OPEN)
  linkFile       String?
  followUpNote   String?
  closedDate     DateTime?
  tags           String?
  valueType      MessageValue?
  companyAnswer  String?
  supportTime    Int?
  benefitTime    Int?
  netTime        Int?
  // Hub fields (Sprint 4A)
  externalId     String?        // ID tin nhắn trên kênh gốc
  externalThread String?        // Thread/conversation ID
  senderName     String?        // Tên người gửi bên ngoài
  senderContact  String?        // Email/phone/zaloId
  rawPayload     Json?          // Payload gốc từ webhook
  replyToId      Int?
  replyTo        Message?       @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]      @relation("MessageReplies")
  attachments    MessageAttachment[]
  createdAt      DateTime       @default(now())

  auditLogs      MessageAuditLog[]

  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, customerId])
  @@index([organizationId, dueDate])
  @@index([organizationId, channel])
  @@map("messages")
}

model MessageAttachment {
  id        String   @id @default(cuid())
  messageId Int
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  name      String
  url       String
  size      Int?
  mimeType  String?
  createdAt DateTime @default(now())

  @@map("message_attachments")
}

model ChannelIntegration {
  id             String         @id @default(cuid())
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel        MessageChannel
  config         Json           // { webhookUrl?, botToken?, appId?, appSecret?, ... } — stored as-is
  isActive       Boolean        @default(true)
  lastSyncAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, channel])
  @@map("channel_integrations")
}

model MessageAuditLog {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageId      Int?
  message        Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actorId        Int?
  actor          Employee?    @relation("MessageAuditActor", fields: [actorId], references: [id])
  action         String
  changes        Json?
  ipAddress      String?
  userAgent      String?      @db.Text
  sessionId      String?
  requestId      String?
  endpoint       String?
  method         String?
  createdAt      DateTime     @default(now())

  @@index([organizationId, messageId])
  @@index([organizationId, requestId])
  @@map("message_audit_logs")
}

// ─────────────────────────────────────────────────────────────
// PASSWORD VAULT
// ─────────────────────────────────────────────────────────────

model PasswordVault {
  id                 Int          @id @default(autoincrement())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scope              VaultScope
  entityName         String?
  customerId         Int?
  customer           Customer?    @relation(fields: [customerId], references: [id])
  serviceApp         String?
  loginUrl           String?
  username           String?
  emailUsed          String?
  passwordEncrypted  String
  twoFaMethod        String?
  twoFaBackup        String?
  ownerId            Int?
  owner              Employee?    @relation("VaultOwner", fields: [ownerId], references: [id])
  createdDate        DateTime     @default(now())
  lastUpdated        DateTime     @updatedAt
  rotationDays       Int?
  notes              String?

  accessLogs VaultAccessLog[]

  @@index([organizationId])
  @@map("password_vault")
}

model VaultAccessLog {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vaultId        Int
  vault          PasswordVault @relation(fields: [vaultId], references: [id])
  accessedById   Int
  accessedBy     Employee     @relation(fields: [accessedById], references: [id])
  accessedAt     DateTime     @default(now())
  action         String?

  @@index([organizationId])
  @@map("vault_access_log")
}

// ─────────────────────────────────────────────────────────────
// WORK RULES
// ─────────────────────────────────────────────────────────────

model WorkRule {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ruleNo         Int
  title          String
  description    String
  effectiveDate  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, ruleNo])
  @@index([organizationId])
  @@map("work_rules")
}

// ─────────────────────────────────────────────────────────────
// USER SESSIONS & API ACCESS LOG
// ─────────────────────────────────────────────────────────────

model UserSession {
  id              String         @id @default(uuid())
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        Employee       @relation(fields: [employeeId], references: [id])

  loginAt         DateTime       @default(now())
  logoutAt        DateTime?
  lastActivityAt  DateTime       @default(now())

  ipAddress       String?
  userAgent       String?        @db.Text
  device          String?
  browser         String?
  os              String?
  country         String?
  city            String?

  loginMethod     SessionLoginMethod @default(CREDENTIALS)
  logoutReason    SessionLogoutReason?

  apiAccessLogs   ApiAccessLog[]
  activities      UserActivity[]

  @@index([organizationId, employeeId, loginAt])
  @@index([organizationId, lastActivityAt])
  @@map("user_sessions")
}

model UserActivity {
  id              BigInt       @id @default(autoincrement())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        Employee     @relation(fields: [employeeId], references: [id])
  sessionId       String
  session         UserSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  date            DateTime     @db.Date

  activeSeconds   Int          @default(0)
  idleSeconds     Int          @default(0)

  pageViews       Json         @default("[]")

  firstActivityAt DateTime
  lastActivityAt  DateTime

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([sessionId, date])
  @@index([organizationId, employeeId, date])
  @@map("user_activity")
}

model ApiAccessLog {
  id             BigInt       @id @default(autoincrement())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  employeeId     Int?
  employee       Employee?    @relation(fields: [employeeId], references: [id])
  sessionId      String?
  session        UserSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  requestId      String?
  endpoint       String
  method         String
  statusCode     Int
  durationMs     Int

  ipAddress      String?
  userAgent      String?      @db.Text
  errorMessage   String?      @db.Text
  responseSize   Int?

  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, employeeId, createdAt])
  @@index([sessionId])
  @@index([statusCode, createdAt])
  @@index([endpoint])
  @@index([requestId])
  @@map("api_access_log")
}

// ─────────────────────────────────────────────────────────────
// ANOMALY ALERTS
// ─────────────────────────────────────────────────────────────

model AnomalyAlert {
  id               Int                @id @default(autoincrement())
  organizationId   String
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type             AnomalyType
  severity         AnomalySeverity    @default(WARNING)

  employeeId       Int?
  employee         Employee?          @relation("AnomalyAlertEmployee", fields: [employeeId], references: [id])

  title            String
  description      String             @db.Text

  auditLogId       Int?
  sessionId        String?
  apiAccessLogId   BigInt?

  metadata         Json?

  status           AnomalyStatus      @default(OPEN)
  acknowledgedById Int?
  acknowledgedBy   Employee?          @relation("AnomalyAlertAcknowledger", fields: [acknowledgedById], references: [id])
  acknowledgedAt   DateTime?
  notes            String?

  dedupKey         String?

  createdAt        DateTime           @default(now())

  @@unique([organizationId, dedupKey])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, employeeId, status])
  @@index([organizationId, type, createdAt])
  @@map("anomaly_alerts")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id             Int          @id @default(autoincrement())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  tableName      String
  recordId       Int?
  action         String
  oldData        Json?
  newData        Json?
  changedById    Int?
  changedBy      Employee?    @relation(fields: [changedById], references: [id])
  changedAt      DateTime     @default(now())
  ipAddress      String?
  userAgent      String?
  sessionId      String?
  requestId      String?
  endpoint       String?
  method         String?

  @@index([organizationId, tableName, recordId])
  @@index([organizationId, changedById, changedAt])
  @@index([requestId])
  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// SYSTEM CONFIG
// ─────────────────────────────────────────────────────────────

model SystemLabel {
  id             Int          @id @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       String
  key            String
  label          String
  color          String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, category, key])
  @@index([organizationId])
  @@map("system_label")
}

