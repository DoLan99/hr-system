generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                 @id @default(cuid())
  clerkOrgId            String                 @unique
  slug                  String                 @unique
  name                  String
  logoUrl               String?
  plan                  Plan                   @default(FREE)
  status                OrgStatus              @default(ACTIVE)
  seatLimit             Int                    @default(1)
  stripeCustomerId      String?                @unique
  stripeSubscriptionId  String?                @unique
  trialEndsAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  anomalyAlerts         AnomalyAlert[]
  apiAccessLogs         ApiAccessLog[]
  auditLogs             AuditLog[]
  careerLevelSkills     CareerLevelSkill[]
  careerLevels          CareerLevel[]
  careerTracks          CareerTrack[]
  channelIntegrations   ChannelIntegration[]
  customerActivities    CustomerActivity[]
  customerContacts      CustomerContact[]
  customers             Customer[]
  departments           Department[]
  developmentGoals      DevelopmentGoal[]
  drivePermissions      DrivePermission[]
  employeeSkills        EmployeeSkill[]
  systemDocuments       SystemDocument[]
  employees             Employee[]
  estimateFlags         EstimateFlag[]
  inventoryAssignments  InventoryAssignment[]
  inventoryCategories   InventoryCategory[]
  inventoryItems        InventoryItem[]
  inventoryTransactions InventoryTransaction[]
  leaves                Leave[]
  messageAuditLogs      MessageAuditLog[]
  messages              Message[]
  microsoftToken        MicrosoftToken?
  officeTimes           OfficeTime[]
  passwordVaults        PasswordVault[]
  payments              Payment[]
  performanceReviews    PerformanceReview[]
  reviewCycles          ReviewCycle[]
  roleSkillRequirements RoleSkillRequirement[]
  roles                 Role[]
  salaryHistory         SalaryHistory[]
  salarySummaries       SalarySummary[]
  skills                Skill[]
  sprints               Sprint[]
  systemLabels          SystemLabel[]
  taskTemplates         TaskTemplate[]
  taskTypeConfigs       TaskTypeConfig[]
  tasks                 Task[]
  teamDepartments       TeamDepartment[]
  teams                 Team[]
  templateSuggestions   TemplateSuggestion[]
  timeLogs              TimeLog[]
  userActivities        UserActivity[]
  userSessions          UserSession[]
  vaultAccessLogs       VaultAccessLog[]
  workRules             WorkRule[]
  upgradeRequests       UpgradeRequest[]
  workflowInstances     WorkflowInstance[]
  workflowTemplates     WorkflowTemplate[]

  @@map("organizations")
}

model Role {
  id                Int                    @id @default(autoincrement())
  organizationId    String
  name              String
  label             String
  description       String?
  color             String?
  permissions       Json                   @default("{}")
  seniority         Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @default(now()) @updatedAt
  employees         Employee[]
  skillRequirements RoleSkillRequirement[]
  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("roles")
}

model Department {
  id             Int              @id @default(autoincrement())
  organizationId String
  name           String
  code           String?
  description    String?
  headId         Int?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  head           Employee?        @relation("DeptHead", fields: [headId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees      Employee[]       @relation("EmployeeDept")
  teams          TeamDepartment[]

  @@unique([organizationId, name])
  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("departments")
}

model Team {
  id             Int              @id @default(autoincrement())
  organizationId String
  name           String
  code           String?
  leadId         Int?
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  employees      Employee[]       @relation("EmployeeTeam")
  departments    TeamDepartment[]
  lead           Employee?        @relation("TeamLead", fields: [leadId], references: [id])
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("teams")
}

model TeamDepartment {
  organizationId String
  teamId         Int
  departmentId   Int
  department     Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([teamId, departmentId])
  @@index([organizationId])
  @@map("team_departments")
}

model Employee {
  id                          Int                    @id @default(autoincrement())
  organizationId              String
  clerkUserId                 String
  membershipRole              MembershipRole         @default(MEMBER)
  isOwner                     Boolean                @default(false)
  employeeCode                String?
  fullName                    String
  avatarUrl                   String?
  department                  String?
  departmentId                Int?
  teamId                      Int?
  roleId                      Int
  company                     String?
  emailCompany                String
  emailGoogle                 String?
  emailPrivate                String?
  mobileCompany               String?
  payType                     PayType                @default(HOURLY)
  hourlyRate                  Decimal?               @db.Decimal(10, 2)
  monthlySalary               Decimal?               @db.Decimal(10, 2)
  maxHoursMonth               Int                    @default(160)
  bonusMPct                   Decimal                @default(0) @db.Decimal(5, 2)
  bonusAPct                   Decimal                @default(0) @db.Decimal(5, 2)
  bonusTPct                   Decimal                @default(0) @db.Decimal(5, 2)
  driveLink1                  String?
  driveLink2                  String?
  driveLink3                  String?
  driveLink4                  String?
  startDate                   DateTime?
  managerId                   Int?
  status                      EmployeeStatus         @default(ACTIVE)
  locale                      String                 @default("en")
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  bankAccount                 String?
  bankBranch                  String?
  bankHolder                  String?
  bankName                    String?
  cccd                        String?
  cccdDate                    DateTime?
  cccdPlace                   String?
  contractEnd                 DateTime?
  contractNo                  String?
  contractStart               DateTime?
  contractType                String?
  currentAddr                 String?
  dob                         DateTime?
  emergencyName               String?
  emergencyPhone              String?
  emergencyRel                String?
  gender                      String?
  nationality                 String?
  permanentAddr               String?
  photoCccdBack               String?
  photoCccdFront              String?
  photoPortrait               String?
  careerLevelId               Int?
  careerTrackId               Int?
  anomalyAcksMade             AnomalyAlert[]         @relation("AnomalyAlertAcknowledger")
  anomalyAlerts               AnomalyAlert[]         @relation("AnomalyAlertEmployee")
  apiAccessLogs               ApiAccessLog[]
  auditLogs                   AuditLog[]
  customerActivities          CustomerActivity[]     @relation("CustomerActivityActor")
  customersManaged            Customer[]             @relation("CustomerStaff")
  departmentsLed              Department[]           @relation("DeptHead")
  developmentGoalsCreated     DevelopmentGoal[]      @relation("EmpGoalCreator")
  developmentGoals            DevelopmentGoal[]      @relation("EmpGoals")
  drivePermissions            DrivePermission[]
  employeeSkills              EmployeeSkill[]        @relation("EmpSkillEmployee")
  systemDocuments             SystemDocument[]       @relation("DocEmployee")
  systemDocumentsUploaded     SystemDocument[]       @relation("DocUploader")
  verifiedEmployeeSkills      EmployeeSkill[]        @relation("EmpSkillVerifier")
  careerLevel                 CareerLevel?           @relation(fields: [careerLevelId], references: [id])
  careerTrack                 CareerTrack?           @relation(fields: [careerTrackId], references: [id])
  dept                        Department?            @relation("EmployeeDept", fields: [departmentId], references: [id])
  manager                     Employee?              @relation("ManagerEmployee", fields: [managerId], references: [id])
  subordinates                Employee[]             @relation("ManagerEmployee")
  organization                Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role                        Role                   @relation(fields: [roleId], references: [id])
  team                        Team?                  @relation("EmployeeTeam", fields: [teamId], references: [id])
  reviewedFlags               EstimateFlag[]         @relation("FlagReviewer")
  inventoryAssignments        InventoryAssignment[]
  inventoryTransactions       InventoryTransaction[]
  approvedLeaves              Leave[]                @relation("LeaveApprover")
  leaves                      Leave[]
  messageAuditLogs            MessageAuditLog[]      @relation("MessageAuditActor")
  messages                    Message[]
  messagesSent                Message[]              @relation("MessagesSent")
  approvedOfficeTimes         OfficeTime[]           @relation("ApprovedBy")
  officeTimes                 OfficeTime[]
  passwordVaultOwned          PasswordVault[]        @relation("VaultOwner")
  paymentsCreated             Payment[]              @relation("PaymentCreator")
  payments                    Payment[]              @relation("PaymentEmployee")
  performanceReviews          PerformanceReview[]    @relation("PerfReviewEmployee")
  performanceReviewsAsManager PerformanceReview[]    @relation("PerfReviewManager")
  reviewCyclesCreated         ReviewCycle[]          @relation("ReviewCycleCreator")
  salaryHistoryMaker          SalaryHistory[]        @relation("SalaryHistoryChanger")
  salaryHistory               SalaryHistory[]
  confirmedSummaries          SalarySummary[]        @relation("SummaryConfirmer")
  salarySummaries             SalarySummary[]
  taskAttachments             TaskAttachment[]
  taskComments                TaskComment[]
  templatesCreated            TaskTemplate[]         @relation("TemplateCreator")
  templatesAssigned           TaskTemplate[]         @relation("TemplateAssignee")
  taskWatches                 TaskWatcher[]
  tasksCreated                Task[]                 @relation("TaskCreator")
  tasksAssigned               Task[]                 @relation("TaskAssignee")
  tasksSupporting             Task[]                 @relation("TaskSupport")
  teamsLed                    Team[]                 @relation("TeamLead")
  templateSuggestions         TemplateSuggestion[]   @relation("SuggestionEmployee")
  reviewedSuggestions         TemplateSuggestion[]   @relation("SuggestionReviewer")
  approvedTimeLogs            TimeLog[]              @relation("TimeLogApprover")
  timeLogs                    TimeLog[]              @relation("TimeLogEmployee")
  userActivities              UserActivity[]
  userSessions                UserSession[]
  vaultAccesses               VaultAccessLog[]
  workflowApprovalsAssigned   WorkflowApproval[]     @relation("WorkflowApprover")
  workflowsInitiated          WorkflowInstance[]     @relation("WorkflowInitiator")

  @@unique([organizationId, emailCompany])
  @@unique([organizationId, employeeCode])
  @@unique([organizationId, clerkUserId])
  @@index([organizationId])
  @@index([clerkUserId])
  @@map("employees")
}

model SalaryHistory {
  id             Int          @id @default(autoincrement())
  organizationId String
  employeeId     Int
  field          String
  oldValue       String?
  newValue       String?
  changedById    Int
  changedAt      DateTime     @default(now())
  changedBy      Employee     @relation("SalaryHistoryChanger", fields: [changedById], references: [id])
  employee       Employee     @relation(fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("salary_history")
}

model Customer {
  id                 Int                @id @default(autoincrement())
  organizationId     String
  custId             String?
  customerName       String?
  businessName       String?
  contactPerson      String?
  phone              String?
  email              String?
  address            String?
  city               String?
  plz                String?
  website            String?
  vatTaxId           String?
  preferredLanguage  String?
  status             CustomerStatus     @default(ACTIVE)
  responsibleStaffId Int?
  lastContactDate    DateTime?
  notes              String?
  createdAt          DateTime           @default(now())
  contractRenewDate  DateTime?
  customerSince      DateTime?
  activities         CustomerActivity[]
  contacts           CustomerContact[]
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  responsibleStaff   Employee?          @relation("CustomerStaff", fields: [responsibleStaffId], references: [id])
  messages           Message[]
  passwordVault      PasswordVault[]
  tasks              Task[]

  @@unique([organizationId, custId])
  @@index([organizationId])
  @@map("customers")
}

model CustomerContact {
  id             Int          @id @default(autoincrement())
  organizationId String
  customerId     Int
  name           String
  role           String?
  email          String?
  phone          String?
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId])
  @@map("customer_contacts")
}

model CustomerActivity {
  id             Int                  @id @default(autoincrement())
  organizationId String
  customerId     Int
  type           CustomerActivityType @default(NOTE)
  content        String
  actorId        Int?
  createdAt      DateTime             @default(now())
  actor          Employee?            @relation("CustomerActivityActor", fields: [actorId], references: [id])
  customer       Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([customerId, createdAt])
  @@map("customer_activities")
}

model TaskTemplate {
  id                   Int            @id @default(autoincrement())
  organizationId       String
  code                 String
  title                String
  description          String?
  defaultEstimatedTime Int?
  defaultPriority      Priority       @default(NORMAL)
  requiresVideo        Boolean?
  department           String?
  linkTemplate         String?
  usageCount           Int            @default(0)
  isActive             Boolean        @default(true)
  createdById          Int?
  createdAt            DateTime       @default(now())
  defaultChecklist     Json?
  defaultLabels        Json?
  defaultTaskType      String         @default("NORMAL")
  defaultAssigneeId    Int?
  estimateFlags        EstimateFlag[]
  createdBy            Employee?      @relation("TemplateCreator", fields: [createdById], references: [id])
  defaultAssignee      Employee?      @relation("TemplateAssignee", fields: [defaultAssigneeId], references: [id])
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks                Task[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@map("task_templates")
}

model Sprint {
  id             Int          @id @default(autoincrement())
  organizationId String
  name           String
  goal           String?
  status         SprintStatus @default(PLANNING)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]

  @@index([organizationId, status])
  @@map("sprints")
}

model Task {
  id                 Int                 @id @default(autoincrement())
  organizationId     String
  code               String
  title              String
  description        String?
  priority           Priority            @default(NORMAL)
  status             TaskStatus          @default(BACKLOG)
  estimatedTime      Int?
  actualTimeTotal    Int                 @default(0)
  progressPct        Int                 @default(0)
  parentTaskId       Int?
  templateId         Int?
  assignedToId       Int
  assignedById       Int
  supportId          Int?
  customerId         Int?
  projectId          Int?
  billable           Boolean             @default(false)
  hourlyRateOverride Decimal?            @db.Decimal(10, 2)
  requiresVideo      Boolean             @default(false)
  videoLink          String?
  dateCreated        DateTime            @default(now())
  dateStarted        DateTime?
  dueDate            DateTime?
  dateCompleted      DateTime?
  isOverdue          Boolean             @default(false)
  lastUpdate         DateTime            @default(now()) @updatedAt
  reasonNextAction   String?
  sprintId           Int?
  storyPoints        Int?
  taskType           String              @default("NORMAL")
  attachments        TaskAttachment[]
  checklistItems     TaskChecklistItem[]
  comments           TaskComment[]
  blockedByDeps      TaskDependency[]    @relation("DependencyDependsOn")
  blockingDeps       TaskDependency[]    @relation("DependencyTask")
  recurrence         TaskRecurrence?
  watchers           TaskWatcher[]
  assignedBy         Employee            @relation("TaskCreator", fields: [assignedById], references: [id])
  assignedTo         Employee            @relation("TaskAssignee", fields: [assignedToId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id])
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentTask         Task?               @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subTasks           Task[]              @relation("TaskHierarchy")
  sprint             Sprint?             @relation(fields: [sprintId], references: [id])
  support            Employee?           @relation("TaskSupport", fields: [supportId], references: [id])
  template           TaskTemplate?       @relation(fields: [templateId], references: [id])
  timeLogs           TimeLog[]

  @@unique([organizationId, code])
  @@index([organizationId, sprintId])
  @@index([organizationId, assignedToId, status])
  @@index([organizationId, customerId])
  @@index([organizationId, parentTaskId])
  @@index([organizationId, dueDate])
  @@map("tasks")
}

model TimeLog {
  id                 Int                   @id @default(autoincrement())
  organizationId     String
  taskId             Int
  employeeId         Int
  date               DateTime
  startTime          DateTime?
  endTime            DateTime?
  durationMinutes    Int
  quantity           Int                   @default(1)
  note               String?
  completionPctAfter Int?
  taskStatusAfter    TaskStatus?
  videoCount         Int                   @default(0)
  videoDuration      Int                   @default(0)
  videoLink          String?
  proofLinks         Json                  @default("[]")
  creditedMinutes    Int?
  approvalStatus     TimeLogApprovalStatus @default(PENDING)
  approvedById       Int?
  approvedMinutes    Int?
  approvedAt         DateTime?
  rejectionReason    String?
  rating             Int?
  createdAt          DateTime              @default(now())
  approvedBy         Employee?             @relation("TimeLogApprover", fields: [approvedById], references: [id])
  employee           Employee              @relation("TimeLogEmployee", fields: [employeeId], references: [id])
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  task               Task                  @relation(fields: [taskId], references: [id])

  @@index([organizationId, taskId])
  @@index([organizationId, employeeId, date])
  @@index([organizationId, approvalStatus])
  @@map("time_logs")
}

model OfficeTime {
  id                  Int            @id @default(autoincrement())
  organizationId      String
  date                DateTime
  employeeId          Int
  startWork1          DateTime?
  startLunch          DateTime?
  startWork2          DateTime?
  startAfternoonBreak DateTime?
  startWork3          DateTime?
  endWorkday          DateTime?
  timeLogsTotal       Int            @default(0)
  actualWorked        Int?
  delta               Int?
  explanation         String?
  approvalStatus      ApprovalStatus @default(PENDING)
  approvedById        Int?
  approvedDelta       Int?
  approvedAt          DateTime?
  createdAt           DateTime       @default(now())
  approvedBy          Employee?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  employee            Employee       @relation(fields: [employeeId], references: [id])
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, employeeId])
  @@index([organizationId])
  @@map("office_time")
}

model TemplateSuggestion {
  id                Int            @id @default(autoincrement())
  organizationId    String
  date              DateTime       @default(now())
  employeeId        Int
  proposedCode      String
  proposedTitle     String
  description       String
  proposedEstimate  Int
  evidenceVideoLink String
  exampleTaskIds    Json           @default("[]")
  reasonNote        String
  status            ApprovalStatus @default(PENDING)
  reviewedById      Int?
  createdTemplateId Int?
  decisionNote      String?
  bonusTime         Int            @default(0)
  reviewedAt        DateTime?
  createdAt         DateTime       @default(now())
  proposedTaskType  String         @default("NORMAL")
  employee          Employee       @relation("SuggestionEmployee", fields: [employeeId], references: [id])
  organization      Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedBy        Employee?      @relation("SuggestionReviewer", fields: [reviewedById], references: [id])

  @@index([organizationId])
  @@map("template_suggestions")
}

model EstimateFlag {
  id                Int                @id @default(autoincrement())
  organizationId    String
  templateId        Int
  flaggedAt         DateTime           @default(now())
  currentEstimate   Int
  suggestedEstimate Int
  sampleSize        Int
  status            EstimateFlagStatus @default(OPEN)
  reviewedById      Int?
  reviewedAt        DateTime?
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedBy        Employee?          @relation("FlagReviewer", fields: [reviewedById], references: [id])
  template          TaskTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("estimate_flags")
}

model SalarySummary {
  id                 Int          @id @default(autoincrement())
  organizationId     String
  employeeId         Int
  month              Int
  year               Int
  creditedHours      Decimal      @default(0) @db.Decimal(8, 2)
  workHoursReal      Decimal      @default(0) @db.Decimal(8, 2)
  learnHours         Decimal      @default(0) @db.Decimal(8, 2)
  billableHours      Decimal      @default(0) @db.Decimal(8, 2)
  billableAmount     Decimal      @default(0) @db.Decimal(10, 2)
  deltaHours         Decimal      @default(0) @db.Decimal(8, 2)
  salaryCalc         Decimal      @default(0) @db.Decimal(10, 2)
  bonusCalc          Decimal      @default(0) @db.Decimal(10, 2)
  totalCalc          Decimal      @default(0) @db.Decimal(10, 2)
  salaryPaid         Decimal      @default(0) @db.Decimal(10, 2)
  bonusPaid          Decimal      @default(0) @db.Decimal(10, 2)
  moneyReceived      Decimal      @default(0) @db.Decimal(10, 2)
  deltaMoney         Decimal      @default(0) @db.Decimal(10, 2)
  scoreWorkSpeed     Decimal?     @db.Decimal(5, 2)
  scoreQuality       Decimal?     @db.Decimal(5, 2)
  scoreLearning      Decimal?     @db.Decimal(5, 2)
  scoreDeadlines     Decimal?     @db.Decimal(5, 2)
  scoreInitiative    Decimal?     @db.Decimal(5, 2)
  totalScore         Decimal?     @db.Decimal(5, 2)
  totalTasks         Int          @default(0)
  completedTasks     Int          @default(0)
  openTasks          Int          @default(0)
  overdueTasks       Int          @default(0)
  totalActualTimeH   Decimal      @default(0) @db.Decimal(8, 2)
  totalCreditedTimeH Decimal      @default(0) @db.Decimal(8, 2)
  completionRate     Decimal      @default(0) @db.Decimal(5, 2)
  tasksByType        Json?
  confirmedById      Int?
  confirmedAt        DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  confirmedBy        Employee?    @relation("SummaryConfirmer", fields: [confirmedById], references: [id])
  employee           Employee     @relation(fields: [employeeId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, employeeId, month, year])
  @@index([organizationId])
  @@map("salary_summary")
}

model Payment {
  id             Int          @id @default(autoincrement())
  organizationId String
  date           DateTime
  employeeId     Int
  type           PaymentType
  amount         Decimal      @db.Decimal(10, 2)
  notes          String?
  summaryMonth   Int?
  summaryYear    Int?
  createdById    Int?
  createdAt      DateTime     @default(now())
  createdBy      Employee?    @relation("PaymentCreator", fields: [createdById], references: [id])
  employee       Employee     @relation("PaymentEmployee", fields: [employeeId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("payments")
}

model ReviewCycle {
  id             Int                 @id @default(autoincrement())
  organizationId String
  name           String
  periodType     ReviewPeriodType    @default(QUARTERLY)
  periodStart    DateTime
  periodEnd      DateTime
  selfDueDate    DateTime?
  managerDueDate DateTime?
  status         ReviewCycleStatus   @default(DRAFT)
  createdById    Int
  openedAt       DateTime?
  closedAt       DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  reviews        PerformanceReview[]
  createdBy      Employee            @relation("ReviewCycleCreator", fields: [createdById], references: [id])
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("review_cycles")
}

model PerformanceReview {
  id                         Int              @id @default(autoincrement())
  organizationId             String
  cycleId                    Int
  employeeId                 Int
  status                     PerfReviewStatus @default(PENDING)
  kpiSnapshot                Json?
  selfScoreWorkSpeed         Decimal?         @db.Decimal(5, 2)
  selfScoreQuality           Decimal?         @db.Decimal(5, 2)
  selfScoreLearning          Decimal?         @db.Decimal(5, 2)
  selfScoreDeadlines         Decimal?         @db.Decimal(5, 2)
  selfScoreInitiative        Decimal?         @db.Decimal(5, 2)
  selfTotalScore             Decimal?         @db.Decimal(5, 2)
  selfHighlights             String?
  selfChallenges             String?
  selfGoalsNext              String?
  selfSubmittedAt            DateTime?
  mgrScoreWorkSpeed          Decimal?         @db.Decimal(5, 2)
  mgrScoreQuality            Decimal?         @db.Decimal(5, 2)
  mgrScoreLearning           Decimal?         @db.Decimal(5, 2)
  mgrScoreDeadlines          Decimal?         @db.Decimal(5, 2)
  mgrScoreInitiative         Decimal?         @db.Decimal(5, 2)
  mgrTotalScore              Decimal?         @db.Decimal(5, 2)
  mgrStrengths               String?
  mgrAreasToImprove          String?
  mgrActionItems             String?
  recommendedSalaryAdjustPct Decimal?         @db.Decimal(5, 2)
  recommendedPromotion       String?
  mgrReviewerId              Int?
