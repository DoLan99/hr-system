  createdAt   DateTime           @default(now())
  dependsOn   Task               @relation("DependencyDependsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)
  task        Task               @relation("DependencyTask", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
  @@map("task_dependencies")
}

model TaskChecklistItem {
  id        Int      @id @default(autoincrement())
  taskId    Int
  content   String
  checked   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_checklist_items")
}

model TaskWatcher {
  taskId     Int
  employeeId Int
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([taskId, employeeId])
  @@map("task_watchers")
}

model TaskComment {
  id        Int           @id @default(autoincrement())
  taskId    Int
  authorId  Int
  content   String
  parentId  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt
  deletedAt DateTime?
  author    Employee      @relation(fields: [authorId], references: [id])
  parent    TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   TaskComment[] @relation("CommentReplies")
  task      Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model DevelopmentGoal {
  id             Int          @id @default(autoincrement())
  organizationId String
  employeeId     Int
  title          String
  description    String?
  category       String?
  targetDate     DateTime?
  status         GoalStatus   @default(IN_PROGRESS)
  progressPct    Int          @default(0)
  skillId        Int?
  targetLevel    Int?
  createdById    Int
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdBy      Employee     @relation("EmpGoalCreator", fields: [createdById], references: [id])
  employee       Employee     @relation("EmpGoals", fields: [employeeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  skill          Skill?       @relation(fields: [skillId], references: [id])

  @@index([organizationId, employeeId])
  @@map("development_goals")
}

