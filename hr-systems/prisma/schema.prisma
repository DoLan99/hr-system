generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ROLES & EMPLOYEES
// ─────────────────────────────────────────────────────────────

model Role {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  label       String
  description String?
  color       String?
  permissions Json       @default("{}")
  employees   Employee[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS & TEAMS
// ─────────────────────────────────────────────────────────────

model Department {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  code        String?          @unique
  description String?
  headId      Int?
  head        Employee?        @relation("DeptHead", fields: [headId], references: [id])
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  teams       TeamDepartment[]
  employees   Employee[]       @relation("EmployeeDept")

  @@map("departments")
}

model Team {
  id           Int              @id @default(autoincrement())
  name         String           @unique
  code         String?
  departments  TeamDepartment[]
  leadId       Int?
  lead         Employee?        @relation("TeamLead", fields: [leadId], references: [id])
  description  String?
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  employees    Employee[]       @relation("EmployeeTeam")

  @@map("teams")
}

model TeamDepartment {
  teamId       Int
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([teamId, departmentId])
  @@map("team_departments")
}

model Employee {
  id              Int        @id @default(autoincrement())
  employeeCode    String?    @unique
  fullName        String
  avatarUrl       String?
  department      String?
  departmentId    Int?
  dept            Department? @relation("EmployeeDept", fields: [departmentId], references: [id])
  teamId          Int?
  team            Team?      @relation("EmployeeTeam", fields: [teamId], references: [id])
  roleId          Int
  role            Role       @relation(fields: [roleId], references: [id])
  company         String?
  emailCompany    String    @unique
  emailGoogle     String?
  emailPrivate    String?
  mobileCompany   String?
  payType         PayType   @default(HOURLY)
  hourlyRate      Decimal?  @db.Decimal(10, 2)
  monthlySalary   Decimal?  @db.Decimal(10, 2)
  maxHoursMonth   Int       @default(160)
  bonusMPct       Decimal   @default(0) @db.Decimal(5, 2)
  bonusAPct       Decimal   @default(0) @db.Decimal(5, 2)
  bonusTPct       Decimal   @default(0) @db.Decimal(5, 2)
  driveLink1      String?
  driveLink2      String?
  driveLink3      String?
  driveLink4      String?
  startDate       DateTime?
  managerId       Int?
  manager         Employee?  @relation("ManagerEmployee", fields: [managerId], references: [id])
  subordinates    Employee[] @relation("ManagerEmployee")
  status          EmployeeStatus @default(ACTIVE)
  locale          String    @default("en")
  passwordHash    String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Department/Team head relations
  departmentsLed       Department[]          @relation("DeptHead")
  teamsLed             Team[]                @relation("TeamLead")

  // Tasks & Time Logs
  tasksAssigned        Task[]                @relation("TaskAssignee")
  tasksCreated         Task[]                @relation("TaskCreator")
  timeLogs             TimeLog[]             @relation("TimeLogEmployee")
  approvedTimeLogs     TimeLog[]             @relation("TimeLogApprover")

  // Templates & Reviews
  templatesCreated     TaskTemplate[]        @relation("TemplateCreator")
  templateSuggestions  TemplateSuggestion[]  @relation("SuggestionEmployee")
  reviewedSuggestions  TemplateSuggestion[]  @relation("SuggestionReviewer")
  reviewedFlags        EstimateFlag[]        @relation("FlagReviewer")

  // Other relations
  officeTimes          OfficeTime[]
  salarySummaries      SalarySummary[]
  payments             Payment[]             @relation("PaymentEmployee")
  paymentsCreated      Payment[]             @relation("PaymentCreator")
  leaves               Leave[]
  messages             Message[]
  salaryHistory        SalaryHistory[]
  auditLogs            AuditLog[]
  vaultAccesses        VaultAccessLog[]
  passwordVaultOwned   PasswordVault[]       @relation("VaultOwner")
  customersManaged     Customer[]            @relation("CustomerStaff")
  approvedOfficeTimes  OfficeTime[]          @relation("ApprovedBy")
  approvedLeaves       Leave[]               @relation("LeaveApprover")
  confirmedSummaries   SalarySummary[]       @relation("SummaryConfirmer")
  salaryHistoryMaker   SalaryHistory[]       @relation("SalaryHistoryChanger")

  @@map("employees")
}

model SalaryHistory {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  field      String
  oldValue   String?
  newValue   String?
  changedById Int
  changedBy  Employee @relation("SalaryHistoryChanger", fields: [changedById], references: [id])
  changedAt  DateTime @default(now())

  @@map("salary_history")
}

// ─────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────

model Customer {
  id                Int       @id @default(autoincrement())
  custId            String?   @unique
  customerName      String?
  businessName      String?
  contactPerson     String?
  phone             String?
  email             String?
  address           String?
  city              String?
  plz               String?
  website           String?
  vatTaxId          String?
  preferredLanguage String?
  status            CustomerStatus @default(ACTIVE)
  responsibleStaffId Int?
  responsibleStaff  Employee? @relation("CustomerStaff", fields: [responsibleStaffId], references: [id])
  lastContactDate   DateTime?
  notes             String?
  createdAt         DateTime  @default(now())

  tasks         Task[]
  messages      Message[]
  passwordVault PasswordVault[]

  @@map("customers")
}

// ─────────────────────────────────────────────────────────────
// TASK TEMPLATES (optional shortcuts)
// ─────────────────────────────────────────────────────────────

model TaskTemplate {
  id                    Int       @id @default(autoincrement())
  code                  String    @unique
  title                 String
  description           String?   @db.Text
  defaultTaskType       TaskType  @default(NORMAL)
  defaultEstimatedTime  Int?
  defaultPriority       Priority  @default(NORMAL)
  requiresVideo         Boolean?
  department            String?
  linkTemplate          String?
  usageCount            Int       @default(0)
  isActive              Boolean   @default(true)
  createdById           Int?
  createdBy             Employee? @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt             DateTime  @default(now())

  tasks                 Task[]
  estimateFlags         EstimateFlag[]

  @@index([isActive])
  @@map("task_templates")
}

// ─────────────────────────────────────────────────────────────
// TASKS (unified — replaces task_library + work_list)
// ─────────────────────────────────────────────────────────────

model Task {
  id                  Int        @id @default(autoincrement())
  code                String     @unique // TSK-0001
  title               String
  description         String?    @db.Text
  taskType            TaskType   @default(NORMAL)
  priority            Priority   @default(NORMAL)
  status              TaskStatus @default(BACKLOG)
  estimatedTime       Int?       // phút
  actualTimeTotal     Int        @default(0)
  progressPct         Int        @default(0)

  parentTaskId        Int?
  parentTask          Task?      @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks            Task[]     @relation("TaskHierarchy")

  templateId          Int?
  template            TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  assignedToId        Int
  assignedTo          Employee   @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedById        Int
  assignedBy          Employee   @relation("TaskCreator", fields: [assignedById], references: [id])

  customerId          Int?
  customer            Customer?  @relation(fields: [customerId], references: [id])
  projectId           Int?

  billable            Boolean    @default(false)
  hourlyRateOverride  Decimal?   @db.Decimal(10, 2)
  requiresVideo       Boolean    @default(false)

  dateCreated         DateTime   @default(now())
  dateStarted         DateTime?
  dueDate             DateTime?
  dateCompleted       DateTime?
  isOverdue           Boolean    @default(false)
  lastUpdate          DateTime   @default(now()) @updatedAt
  reasonNextAction    String?

  timeLogs            TimeLog[]

  @@index([assignedToId, status])
  @@index([customerId])
  @@index([parentTaskId])
  @@index([dueDate])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────
// TIME LOGS (replaces work_reports)
// ─────────────────────────────────────────────────────────────

model TimeLog {
  id                   Int                @id @default(autoincrement())
  taskId               Int
  task                 Task               @relation(fields: [taskId], references: [id], onDelete: Restrict)
  employeeId           Int
  employee             Employee           @relation("TimeLogEmployee", fields: [employeeId], references: [id])

  date                 DateTime
  startTime            DateTime?
  endTime              DateTime?
  durationMinutes      Int
  quantity             Int                @default(1)
  note                 String?            @db.Text
  completionPctAfter   Int?
  taskStatusAfter      TaskStatus?

  // proof
  videoCount           Int                @default(0)
  videoDuration        Int                @default(0)
  videoLink            String?
  proofLinks           Json               @default("[]")

  // approval
  creditedMinutes      Int?
  approvalStatus       TimeLogApprovalStatus @default(PENDING)
  approvedById         Int?
  approvedBy           Employee?          @relation("TimeLogApprover", fields: [approvedById], references: [id])
  approvedMinutes      Int?
  approvedAt           DateTime?
  rejectionReason      String?
  rating               Int?

  createdAt            DateTime           @default(now())

  @@index([taskId])
  @@index([employeeId, date])
  @@index([approvalStatus])
  @@map("time_logs")
}

// ─────────────────────────────────────────────────────────────
// OFFICE TIME
// ─────────────────────────────────────────────────────────────

model OfficeTime {
  id                   Int            @id @default(autoincrement())
  date                 DateTime
  employeeId           Int
  employee             Employee       @relation(fields: [employeeId], references: [id])
  startWork1           DateTime?
  startLunch           DateTime?
  startWork2           DateTime?
  startAfternoonBreak  DateTime?
  startWork3           DateTime?
  endWorkday           DateTime?
  timeLogsTotal        Int            @default(0)
  actualWorked         Int?
  delta                Int?
  explanation          String?
  approvalStatus       ApprovalStatus @default(PENDING)
  approvedById         Int?
  approvedBy           Employee?      @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedDelta        Int?
  approvedAt           DateTime?
  createdAt            DateTime       @default(now())

  @@unique([date, employeeId])
  @@map("office_time")
}

// ─────────────────────────────────────────────────────────────
// TASK REVIEWS — Template Suggestions + Estimate Flags
// ─────────────────────────────────────────────────────────────

model TemplateSuggestion {
  id                    Int            @id @default(autoincrement())
  date                  DateTime       @default(now())
  employeeId            Int
  employee              Employee       @relation("SuggestionEmployee", fields: [employeeId], references: [id])
  proposedCode          String
  proposedTitle         String
  description           String         @db.Text
  proposedTaskType      TaskType
  proposedEstimate      Int
  evidenceVideoLink     String
  exampleTaskIds        Json           @default("[]")
  reasonNote            String         @db.Text
  status                ApprovalStatus @default(PENDING)
  reviewedById          Int?
  reviewedBy            Employee?      @relation("SuggestionReviewer", fields: [reviewedById], references: [id])
  createdTemplateId     Int?
  decisionNote          String?
  bonusTime             Int            @default(0)
  reviewedAt            DateTime?
  createdAt             DateTime       @default(now())

  @@map("template_suggestions")
}

model EstimateFlag {
  id                    Int                @id @default(autoincrement())
  templateId            Int
  template              TaskTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flaggedAt             DateTime           @default(now())
  currentEstimate       Int
  suggestedEstimate     Int
  sampleSize            Int
  status                EstimateFlagStatus @default(OPEN)
  reviewedById          Int?
  reviewedBy            Employee?          @relation("FlagReviewer", fields: [reviewedById], references: [id])
  reviewedAt            DateTime?

  @@map("estimate_flags")
}

// ─────────────────────────────────────────────────────────────
// SUMMARY & PAYMENTS
// ─────────────────────────────────────────────────────────────

model SalarySummary {
  id                     Int       @id @default(autoincrement())
  employeeId             Int
  employee               Employee  @relation(fields: [employeeId], references: [id])
  month                  Int
  year                   Int
  // Hours
  creditedHours          Decimal   @default(0) @db.Decimal(8, 2)
  workHoursReal          Decimal   @default(0) @db.Decimal(8, 2)
  learnHours             Decimal   @default(0) @db.Decimal(8, 2)
  billableHours          Decimal   @default(0) @db.Decimal(8, 2)
  billableAmount         Decimal   @default(0) @db.Decimal(10, 2)
  deltaHours             Decimal   @default(0) @db.Decimal(8, 2)
  // Payroll (€)
  salaryCalc             Decimal   @default(0) @db.Decimal(10, 2)
  bonusCalc              Decimal   @default(0) @db.Decimal(10, 2)
  totalCalc              Decimal   @default(0) @db.Decimal(10, 2)
  salaryPaid             Decimal   @default(0) @db.Decimal(10, 2)
  bonusPaid              Decimal   @default(0) @db.Decimal(10, 2)
  moneyReceived          Decimal   @default(0) @db.Decimal(10, 2)
  deltaMoney             Decimal   @default(0) @db.Decimal(10, 2)
  // Performance scores
  scoreWorkSpeed         Decimal?  @db.Decimal(5, 2)
  scoreQuality           Decimal?  @db.Decimal(5, 2)
  scoreLearning          Decimal?  @db.Decimal(5, 2)
  scoreDeadlines         Decimal?  @db.Decimal(5, 2)
  scoreInitiative        Decimal?  @db.Decimal(5, 2)
  totalScore             Decimal?  @db.Decimal(5, 2)
  // Task stats
  totalTasks             Int       @default(0)
  completedTasks         Int       @default(0)
  openTasks              Int       @default(0)
  overdueTasks           Int       @default(0)
  totalActualTimeH       Decimal   @default(0) @db.Decimal(8, 2)
  totalCreditedTimeH     Decimal   @default(0) @db.Decimal(8, 2)
  completionRate         Decimal   @default(0) @db.Decimal(5, 2)
  tasksByType            Json?
  // Status
  confirmedById          Int?
  confirmedBy            Employee? @relation("SummaryConfirmer", fields: [confirmedById], references: [id])
  confirmedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([employeeId, month, year])
  @@map("salary_summary")
}

model Payment {
  id           Int         @id @default(autoincrement())
  date         DateTime
  employeeId   Int
  employee     Employee    @relation("PaymentEmployee", fields: [employeeId], references: [id])
  type         PaymentType
  amount       Decimal     @db.Decimal(10, 2)
  notes        String?
  summaryMonth Int?
  summaryYear  Int?
  createdById  Int?
  createdBy    Employee?   @relation("PaymentCreator", fields: [createdById], references: [id])
  createdAt    DateTime    @default(now())

  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// LEAVE MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Leave {
  id               Int            @id @default(autoincrement())
  date             DateTime
  employeeId       Int
  employee         Employee       @relation(fields: [employeeId], references: [id])
  type             LeaveType
  requestedHours   Decimal        @db.Decimal(5, 2)
  reason           String?
  evidenceLink     String?
  status           ApprovalStatus @default(PENDING)
  approvedHours    Decimal?       @db.Decimal(5, 2)
  approvalNote     String?
  approvedById     Int?
  approvedBy       Employee?      @relation("LeaveApprover", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  money            Decimal?       @db.Decimal(10, 2)
  createdAt        DateTime       @default(now())

  @@map("leaves")
}

// ─────────────────────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────────────────────

model Message {
  id             Int            @id @default(autoincrement())
  date           DateTime
  time           DateTime?
  channel        MessageChannel?
  customerId     Int?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  subject        String?
  messageSummary String?
  actionRequired String?
  assignedToId   Int?
  assignedTo     Employee?      @relation(fields: [assignedToId], references: [id])
  dueDate        DateTime?
  status         MessageStatus  @default(OPEN)
  linkFile       String?
  followUpNote   String?
  closedDate     DateTime?
  tags           String?
  valueType      MessageValue?
  companyAnswer  String?
  supportTime    Int?
  benefitTime    Int?
  netTime        Int?
  createdAt      DateTime       @default(now())

  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// PASSWORD VAULT
// ─────────────────────────────────────────────────────────────

model PasswordVault {
  id                 Int       @id @default(autoincrement())
  scope              VaultScope
  entityName         String?
  customerId         Int?
  customer           Customer? @relation(fields: [customerId], references: [id])
  serviceApp         String?
  loginUrl           String?
  username           String?
  emailUsed          String?
  passwordEncrypted  String
  twoFaMethod        String?
  twoFaBackup        String?
  ownerId            Int?
  owner              Employee? @relation("VaultOwner", fields: [ownerId], references: [id])
  createdDate        DateTime  @default(now())
  lastUpdated        DateTime  @updatedAt
  rotationDays       Int?
  notes              String?

  accessLogs VaultAccessLog[]

  @@map("password_vault")
}

model VaultAccessLog {
  id          Int           @id @default(autoincrement())
  vaultId     Int
  vault       PasswordVault @relation(fields: [vaultId], references: [id])
  accessedById Int
  accessedBy  Employee      @relation(fields: [accessedById], references: [id])
  accessedAt  DateTime      @default(now())
  action      String?

  @@map("vault_access_log")
}

// ─────────────────────────────────────────────────────────────
// WORK RULES
// ─────────────────────────────────────────────────────────────

model WorkRule {
  id            Int      @id @default(autoincrement())
  ruleNo        Int
  title         String
  description   String
  effectiveDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("work_rules")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          Int      @id @default(autoincrement())
  tableName   String
  recordId    Int?
  action      String
  oldData     Json?
  newData     Json?
  changedById Int?
  changedBy   Employee? @relation(fields: [changedById], references: [id])
  changedAt   DateTime @default(now())
  ipAddress   String?

  @@map("audit_log")
}

// ─────────────────────────────────────────────────────────────
// SYSTEM CONFIG
// ─────────────────────────────────────────────────────────────

model SystemLabel {
  id        Int      @id @default(autoincrement())
  category  String
  key       String
  label     String
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([category, key])
  @@map("system_label")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum PayType {
  HOURLY
  MONTHLY
  CONTRACT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  PROBATION
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum Priority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum TaskType {
  NORMAL
  LEARNING
  NEW_RESEARCH
  MEETING
  ADMIN
  BILLABLE_CLIENT
  INTERNAL
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  BLOCKED
  REVIEW
  DONE
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimeLogApprovalStatus {
  AUTO_APPROVED
  PENDING
  APPROVED
  REJECTED
}

enum EstimateFlagStatus {
  OPEN
  ACCEPTED
  DISMISSED
}

enum PaymentType {
  SALARY
  BONUS
  ADVANCE
  DEDUCTION
  OTHER
}

enum LeaveType {
  VACATION
  HOLIDAY
  ILLNESS
  OTHER
}

enum MessageChannel {
  EMAIL
  SLACK
  PHONE
  ZALO
  CHAT
  OTHER
}

enum MessageStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum MessageValue {
  A
  B
  C
}

enum VaultScope {
  COMPANY
  CUSTOMER
}
